{
  "rewrites": [
    {
      "source": "/listing/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|facebot|twitterbot|whatsapp|linkedinbot|slackbot|slack-imgproxy|telegrambot|discordbot|pinterest|redditbot|googlebot|bingbot|applebot|skypeuripreview|embedly|iframely|vkshare|w3c_validator|developers\\.google\\.com|bot|crawler|spider|preview).*"
        }
      ],
      "destination": "/api/og?id=:id"
    },
    { "source": "/((?!api/|Images/|.*\\.).*)", "destination": "/index.html" }
  ]
}
